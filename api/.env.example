# OpenAI — required.
OPENAI_API_KEY=

# CORS — comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:3000

# Supabase — leave blank to disable auth (self-host mode).
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

# Optional Sentry telemetry.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
